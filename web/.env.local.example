# Sao chép file này thành .env.local (đã bị .gitignore mặc định bởi Next.js) rồi điền giá trị thật.
# KHÔNG commit .env.local, KHÔNG dán API key vào chat/PR.

# FPT AI Marketplace (MKP) — endpoint OpenAI-compatible, đã xác minh thật:
#   GET  {MKP_API_BASE}/v1/models            — danh sách model khả dụng với key của bạn
#   POST {MKP_API_BASE}/v1/chat/completions  — gọi model
MKP_API_KEY=
MKP_API_BASE=https://mkp-api.fptcloud.com

# Model mặc định đã chọn: SaoLa3.1-medium (model tiếng Việt, trả content sạch — không lẫn
# reasoning_content như DeepSeek-V4-Flash/GLM-5.2 trên cùng marketplace). Model khác đã thử
# và cũng cho content sạch: Llama-3.3-70B-Instruct, gpt-oss-120b, gpt-oss-20b, Qwen3.6-27B.
MKP_API_MODEL=SaoLa3.1-medium
